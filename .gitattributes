# Auto-detect text files and normalize to LF in repo
* text=auto eol=lf

# Frontend (React, JS, JSX, TS, TSX, CSS, HTML, JSON)
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Backend (Python / Node)
*.py   text eol=lf
*.env  text eol=lf

# Config files
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini  text eol=lf
*.cfg  text eol=lf

# Ignore line endings in binaries
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.ttf  binary
*.woff binary
*.woff2 binary
*.eot  binary
*.zip  binary
*.exe  binary
*.dll  binary
